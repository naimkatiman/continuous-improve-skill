# continuous-improvement — social media credentials
# Copy this file: cp .env.example .env
# Then fill in your keys. Never commit .env to git.

# X / Twitter — https://developer.x.com/en/portal/dashboard
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

