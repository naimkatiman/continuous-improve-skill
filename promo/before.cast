[1.85, "o", "\u001b[1m\u001b[34m│\u001b[0m  Claude Code v1.0.8                                    \u001b[1m\u001b[34m│\u001b[0m\r\n"]
[1.9, "o", "\u001b[1m\u001b[34m╰─────────────────────────────────────────────────────────╯\u001b[0m\r\n\r\n"]
[2.2, "o", "\u001b[1m>\u001b[0m "]
