[7.0, "o", "\r\n\r\n"]
[7.4, "o", "\u001b[36mв‘  Research\u001b[0m\r\n"]
[7.7, "o", "  Checking existing code and dependencies...\r\n"]
[8.0, "o", "  \u001b[2mRead  package.json\u001b[0m\r\n"]
[8.3, "o", "  \u001b[2mRead  server.js\u001b[0m\r\n"]
[8.6, "o", "  \u001b[2mGrep  \"cache\" across project\u001b[0m\r\n"]
[8.9, "o", "  в†’ No existing cache. Single Express server, 1 route.\r\n"]
[9.1, "o", "  в†’ node-cache fits (no Redis needed for single-server).\r\n\r\n"]
[9.5, "o", "\u001b[36mв‘Ў Plan\u001b[0m\r\n"]
[9.7, "o", "  вЂў Add node-cache to package.json\r\n"]
[9.9, "o", "  вЂў Wrap /data route with TTL cache (60s)\r\n"]
[10.1, "o", "  \u001b[31mвњ— Anti-scope:\u001b[0m No Redis. No CDN. No cache-clear endpoint.\r\n\r\n"]
[10.5, "o", "\u001b[36mв‘ў Execute\u001b[0m вЂ” one change\r\n"]
[10.8, "o", "  \u001b[2m  Edit  server.js (+8 lines)\u001b[0m\r\n"]
[11.0, "o", "\r\n"]
[11.1, "o", "  \u001b[32m+  const NodeCache = require('node-cache');\u001b[0m\r\n"]
[11.2, "o", "  \u001b[32m+  const cache = new NodeCache({ stdTTL: 60 });\u001b[0m\r\n"]
[11.3, "o", "  \u001b[32m+\u001b[0m\r\n"]
[11.4, "o", "  \u001b[32m+  app.get('/data', (req, res) => {\u001b[0m\r\n"]
[11.5, "o", "  \u001b[32m+    const hit = cache.get('data');\u001b[0m\r\n"]
[11.6, "o", "  \u001b[32m+    if (hit) return res.json(hit);\u001b[0m\r\n"]
[11.7, "o", "  \u001b[32m+    const result = { ok: 1 };\u001b[0m\r\n"]
[11.8, "o", "  \u001b[32m+    cache.set('data', result);\u001b[0m\r\n"]
[11.9, "o", "  \u001b[32m+    res.json(result);\u001b[0m\r\n"]
[12.0, "o", "  \u001b[32m+  });\u001b[0m\r\n"]
[12.2, "o", "\r\n"]
[12.5, "o", "\u001b[36mв‘Ј Verify\u001b[0m\r\n"]
[12.8, "o", "  \u001b[2m  Bash  npm install node-cache\u001b[0m\r\n"]
[13.0, "o", "  \u001b[32mвњ“\u001b[0m added 1 package\r\n"]
[13.3, "o", "  \u001b[2m  Bash  node -e \"require('./server')\" &\u001b[0m\r\n"]
[13.5, "o", "  \u001b[32mвњ“\u001b[0m Server starts on :3000\r\n"]
